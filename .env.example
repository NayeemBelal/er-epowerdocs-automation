# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret sent by the webhook caller in the X-Webhook-Secret header.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=replace_with_a_strong_random_secret

# ── EPOWERdoc Process ─────────────────────────────────────────────────────────
# Exact executable name as it appears in Windows Task Manager.
EPOWER_PROCESS_NAME=EPD.exe

# ── UI Timing (seconds) ───────────────────────────────────────────────────────
# How long pywinauto waits for windows/controls to appear before timing out.
UI_TIMEOUT=10
